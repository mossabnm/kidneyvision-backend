APP_NAME="KidneyVision AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kidney_vision
DB_USERNAME=root
DB_PASSWORD=

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

AI_FLASK_BASE_URL=http://127.0.0.1:5000
AI_PREDICT_ENDPOINT=/predict
AI_HEALTH_ENDPOINT=/health
AI_TIMEOUT=30
AI_RETRY_TIMES=3
AI_RETRY_SLEEP=1000
AI_MOCK_ENABLED=true

FILESYSTEM_DISK=local
